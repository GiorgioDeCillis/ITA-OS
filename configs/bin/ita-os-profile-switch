#!/bin/bash
# ============================================================
# ita-os-profile-switch
# ============================================================
# Switch between ITA-OS desktop profiles:
#   - windows  : KDE Plasma with Windows-like layout
#   - mac      : KDE Plasma with macOS-like layout
#   - hyprland : Omarchy's native tiling WM (default)
#
# Usage:
#   ita-os-profile-switch windows
#   ita-os-profile-switch mac
#   ita-os-profile-switch hyprland
#   ita-os-profile-switch --list
#   ita-os-profile-switch --current
# ============================================================

set -euo pipefail

# Paths
ITA_OS_PROFILES="${ITA_OS_PROFILES:-$HOME/.local/share/ita-os/profiles}"
ITA_OS_STATE="${ITA_OS_STATE:-$HOME/.local/state/ita-os}"
PLASMA_CONFIG_DIR="$HOME/.config"
SDDM_CONF="/etc/sddm.conf.d/ita-os.conf"
CURRENT_PROFILE_FILE="$ITA_OS_STATE/current-profile"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color
BOLD='\033[1m'

# ITA-OS Banner
banner() {
    echo -e "${GREEN}"
    echo "  ╔══════════════════════════════════════╗"
    echo "  ║     🇮🇹  ITA-OS Profile Switcher      ║"
    echo "  ╚══════════════════════════════════════╝"
    echo -e "${NC}"
}

# Get current profile
get_current() {
    if [[ -f "$CURRENT_PROFILE_FILE" ]]; then
        cat "$CURRENT_PROFILE_FILE"
    else
        echo "hyprland"
    fi
}

# List available profiles
list_profiles() {
    local current
    current=$(get_current)
    echo -e "${BOLD}Available profiles:${NC}"
    echo ""
    for profile in windows mac hyprland; do
        local marker=" "
        [[ "$profile" == "$current" ]] && marker="●"
        case $profile in
            windows)
                echo -e "  ${marker} ${BLUE}windows${NC}   — KDE Plasma, Windows-like (taskbar + Start menu)"
                ;;
            mac)
                echo -e "  ${marker} ${BLUE}mac${NC}       — KDE Plasma, macOS-like (top bar + dock)"
                ;;
            hyprland)
                echo -e "  ${marker} ${BLUE}hyprland${NC}  — Omarchy default (tiling WM, keyboard-driven)"
                ;;
        esac
    done
    echo ""
    echo -e "Current: ${GREEN}${BOLD}$(get_current)${NC}"
}

# Backup current KDE configuration
backup_kde_config() {
    local backup_dir="$ITA_OS_STATE/backup-$(date +%Y%m%d-%H%M%S)"
    mkdir -p "$backup_dir"

    for file in plasma-org.kde.plasma.desktop-appletsrc kwinrc kdeglobals; do
        if [[ -f "$PLASMA_CONFIG_DIR/$file" ]]; then
            cp "$PLASMA_CONFIG_DIR/$file" "$backup_dir/"
        fi
    done

    echo -e "${YELLOW}Backup saved to: $backup_dir${NC}"
}

# Apply KDE profile
apply_kde_profile() {
    local profile_name="$1"
    local profile_dir="$ITA_OS_PROFILES/$profile_name/plasma"

    if [[ ! -d "$profile_dir" ]]; then
        echo -e "${RED}Error: Profile directory not found: $profile_dir${NC}"
        exit 1
    fi

    # Backup existing config
    backup_kde_config

    # Stop KDE Plasma if running
    if pgrep -x plasmashell > /dev/null 2>&1; then
        echo "Stopping Plasma shell..."
        kquitapp6 plasmashell 2>/dev/null || killall plasmashell 2>/dev/null || true
        sleep 2
    fi

    # Copy profile configs
    for file in plasma-org.kde.plasma.desktop-appletsrc kwinrc kdeglobals; do
        if [[ -f "$profile_dir/$file" ]]; then
            cp "$profile_dir/$file" "$PLASMA_CONFIG_DIR/$file"
            echo -e "  Applied: ${GREEN}$file${NC}"
        fi
    done

    # Restart KDE Plasma if we're in a KDE session
    if [[ "${XDG_CURRENT_DESKTOP:-}" == *"KDE"* ]]; then
        echo "Restarting Plasma shell..."
        nohup plasmashell --replace > /dev/null 2>&1 &
        disown
        sleep 2

        # Reconfigure KWin
        if pgrep -x kwin_wayland > /dev/null 2>&1 || pgrep -x kwin_x11 > /dev/null 2>&1; then
            qdbus6 org.kde.KWin /KWin reconfigure 2>/dev/null || true
        fi
    fi
}

# Switch to Hyprland
apply_hyprland_profile() {
    echo -e "  Hyprland uses the default Omarchy configuration."
    echo -e "  No file changes needed — just log out and select Hyprland."
}

# Set default session in SDDM
set_default_session() {
    local session="$1"
    local session_file

    case $session in
        plasma)
            session_file="plasma"
            ;;
        hyprland)
            session_file="hyprland"
            ;;
    esac

    echo -e "  Default session: ${GREEN}$session_file${NC}"
    echo -e "${YELLOW}  (Requires sudo to update SDDM config)${NC}"

    # Only write SDDM config if user has sudo
    if sudo -n true 2>/dev/null; then
        sudo mkdir -p "$(dirname "$SDDM_CONF")"
        echo -e "[Autologin]\nSession=$session_file" | sudo tee "$SDDM_CONF" > /dev/null
    else
        echo -e "  ${YELLOW}Run manually: sudo mkdir -p /etc/sddm.conf.d && echo '[Autologin]' | sudo tee $SDDM_CONF && echo 'Session=$session_file' | sudo tee -a $SDDM_CONF${NC}"
    fi
}

# Save current profile state
save_profile() {
    local profile="$1"
    mkdir -p "$ITA_OS_STATE"
    echo "$profile" > "$CURRENT_PROFILE_FILE"
}

# Main switch logic
switch_profile() {
    local target="$1"
    local current
    current=$(get_current)

    if [[ "$target" == "$current" ]]; then
        echo -e "${YELLOW}Already using profile: $target${NC}"
        exit 0
    fi

    banner
    echo -e "Switching: ${RED}$current${NC} → ${GREEN}${BOLD}$target${NC}"
    echo ""

    case $target in
        windows|windows-like)
            target="windows-like"
            apply_kde_profile "windows-like"
            set_default_session "plasma"
            save_profile "windows"
            ;;
        mac|mac-like)
            target="mac-like"
            apply_kde_profile "mac-like"
            set_default_session "plasma"
            save_profile "mac"
            ;;
        hyprland)
            apply_hyprland_profile
            set_default_session "hyprland"
            save_profile "hyprland"
            ;;
        *)
            echo -e "${RED}Unknown profile: $target${NC}"
            echo "Available: windows, mac, hyprland"
            exit 1
            ;;
    esac

    echo ""
    echo -e "${GREEN}${BOLD}✓ Profile switched to: $target${NC}"
    echo -e "${YELLOW}  Log out and back in for full effect.${NC}"
}

# Entry point
main() {
    case "${1:-}" in
        --list|-l)
            list_profiles
            ;;
        --current|-c)
            get_current
            ;;
        --help|-h|"")
            banner
            echo "Usage: ita-os-profile-switch <profile>"
            echo ""
            list_profiles
            echo ""
            echo "Options:"
            echo "  --list, -l      List available profiles"
            echo "  --current, -c   Show current profile"
            echo "  --help, -h      Show this help"
            ;;
        *)
            switch_profile "$1"
            ;;
    esac
}

main "$@"
