package() {
    echo "TODO: Implement package step"
    # cd "${srcdir}/cie-middleware-linux-${pkgver}/build"
    # make DESTDIR="${pkgdir}" install
    
    # Install udev rules for smart card readers
    install -Dm644 /dev/null "${pkgdir}/usr/lib/udev/rules.d/90-cie.rules"
    echo '# CIE Smart Card Reader rules' > "${pkgdir}/usr/lib/udev/rules.d/90-cie.rules"
    echo 'ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="*", ATTR{idProduct}=="*", TAG+="systemd", ENV{SYSTEMD_WANTS}="pcscd.service"' >> "${pkgdir}/usr/lib/udev/rules.d/90-cie.rules"
    
    # Enable pcscd service
    install -dm755 "${pkgdir}/usr/lib/systemd/system/multi-user.target.wants"
}
